NODE_ENV=development
PORT=3000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=devtask_db
DB_USER=devtask_user
DB_PASSWORD=devtask_pass

# Redis Configuration (v0.3 - required)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Session Configuration (v0.3 - replaces JWT)
SESSION_SECRET=your_session_secret_here_minimum_32_characters_required
SESSION_NAME=devtask.sid
SESSION_MAX_AGE=604800000

# Cookie Configuration
COOKIE_SECURE=false
COOKIE_DOMAIN=

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Logging
LOG_LEVEL=debug

# Legacy JWT (deprecated in v0.3, remove after migration complete)
# JWT_SECRET=your-super-secret-jwt-key-change-in-production
# JWT_EXPIRES_IN=24h
